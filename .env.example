# Database Connection Strings
# Define all your environments here

# Local Development
DATABASE_URL_LOCAL=postgresql+psycopg://jewelry_user:jewelry_pass@localhost:5432/jewelry_db

# Development
DATABASE_URL_DEV=postgresql://user:pass@dev-host:5432/jewelry_dev

# Staging
DATABASE_URL_STAGING=postgresql://user:pass@staging-host:5432/jewelry_staging

# Production
DATABASE_URL_PROD=postgresql://user:pass@production-host:5432/jewelry_production

# Active Database (change this to switch environments)
# Options: ${DATABASE_URL_LOCAL}, ${DATABASE_URL_DEV}, ${DATABASE_URL_STAGING}, ${DATABASE_URL_PROD}
DATABASE_URL=${DATABASE_URL_LOCAL}

SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
ENVIRONMENT=development

# Metal Price API Configuration
METAL_PRICE_API_URL=https://api.metalpriceapi.com/v1
METAL_PRICE_API_KEY=your-api-key-here
METAL_PRICE_CACHE_TTL_MINUTES=15
